{
    "description": "(WES) CAPSLOCK",
    "manipulators": [
        {
            "conditions": [
                { "name": "caps_layer", "type": "variable_if", "value": 1 },
                { "name": "mirror_enabled", "type": "variable_if", "value": 0 },
                { "name": "mirror", "type": "variable_if", "value": 0 }
            ],
            "from": { "key_code": "spacebar", "modifiers": { "optional": ["any"] } },
            "to": [{ "key_code": "left_shift", "lazy": true }],
            "type": "basic"
        },
        {
            "conditions": [{ "name": "mirror", "type": "variable_if", "value": 0 }],
            "from": {
                "key_code": "caps_lock",
                "modifiers": { "optional": ["any"] }
            },
            "to": [
                {
                    "set_variable": {
                        "name": "caps_layer",
                        "value": 1
                    }
                }
            ],
            "to_after_key_up": [
                {
                    "set_variable": {
                        "name": "caps_layer",
                        "value": 0
                    }
                }
            ],
            "to_if_alone": [{ "key_code": "caps_lock" }],
            "type": "basic"
        }
    ]
}